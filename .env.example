# Copy to .env and fill in real values. NEVER commit .env.
# docker-compose.yml reads these via ${VAR} references.

# ---- Images ----
IMAGE_TAG_BACK=skylogsio/skylogs-api:latest
IMAGE_TAG_FRONT=skylogsio/skylogs-frontend:latest
IMAGE_TAG_SENTINEL=skylogsio/skylogs-sentinel:latest

# ---- URLs ----
APP_URL=https://skylogs.example.com/api
FRONTEND_URL=https://skylogs.example.com
NEXTAUTH_URL=https://skylogs.example.com

# ---- Secrets (generate strong values!) ----
# openssl rand -base64 32
NEXTAUTH_SECRET=
# openssl rand -hex 32
JWT_SECRET=

# ---- MongoDB ----
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=

# ---- Redis ----
REDIS_PASSWORD=
